#!ipxe
# Auto-generated by Landscape. Re-render from the Provisioning page.

set server {{ server_ip }}
set http  http://${server}:{{ http_port }}

# Per-machine config first: one file per MAC. Falls through to the menu
# when this MAC has no machine registered.
chain --autofree ${http}/clients/${mac:hexhyp}.ipxe || goto menu

:menu
menu Landscape provisioning
item --gap --             ---- Registered machines ----
{% for m in machines %}
item machine_{{ m.id }}      {{ m.hostname }} ({{ m.mac_hyph }}){% if m.image %} - {{ m.image.name }}{% endif %}

{% endfor %}
item --gap --             ---- Other ----
item --key s shell        (s) iPXE shell
item --key r reboot       (r) Reboot
item --key e exit         (e) Exit to local boot
choose --default exit --timeout 30000 target && goto ${target}

{% for m in machines %}
:machine_{{ m.id }}
chain --autofree ${http}/clients/{{ m.mac_hyph }}.ipxe || goto menu
{% endfor %}

:shell
shell
goto menu

:reboot
reboot

:exit
exit
