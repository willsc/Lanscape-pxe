# Auto-generated by Landscape. Edit via the PXE / DHCP page, not by hand.
# Mode: {{ dhcp.mode }}{% if dhcp.mode == "auto" %} (resolved: {{ resolved_mode }}){% endif %}

port=0
log-dhcp
enable-tftp
tftp-root=/var/lib/tftpboot

{% if effective_mode == "proxy" %}
# Proxy-DHCP mode: the existing DHCP server hands out IPs; we only add the
# PXE boot hints. Safe alongside your router/DHCP.
dhcp-range={{ subnet }},proxy
{% else %}
# Full DHCP-server mode: we hand out leases too. Do NOT run this alongside
# another DHCP server on the same broadcast domain.
dhcp-range={{ dhcp.range_start }},{{ dhcp.range_end }},{{ dhcp.netmask or "255.255.255.0" }},{{ dhcp.lease_time or "12h" }}
{% if dhcp.gateway %}
dhcp-option=3,{{ dhcp.gateway }}
{% endif %}
{% if dhcp.dns %}
dhcp-option=6,{{ dhcp.dns | join(",") }}
{% endif %}
{% endif %}

# Tag BIOS vs UEFI clients off the client-arch DHCP option.
dhcp-match=set:bios,option:client-arch,0
dhcp-match=set:uefi,option:client-arch,7
dhcp-match=set:uefi,option:client-arch,9

# Hand the right iPXE binary to each.
dhcp-boot=tag:bios,undionly.kpxe,,{{ server_ip }}
dhcp-boot=tag:uefi,ipxe.efi,,{{ server_ip }}

# Once iPXE has loaded and re-DHCPs (user-class "iPXE"), chain to the
# HTTP-served menu.
dhcp-userclass=set:ipxe,iPXE
dhcp-boot=tag:ipxe,http://{{ server_ip }}:{{ http_port }}/boot.ipxe
